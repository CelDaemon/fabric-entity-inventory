{
	"schemaVersion": 1,
	"id": "entity-inventory",
	"version": "${version}",
	"name": "Entity Inventory",
	"description": "An example mod to show creating an entity with a custom inventory.",
	"authors": [
		"CeLDaemon"
	],
	"contact": {
		"homepage": "https://github.com/CeLDaemon/fabric-entity-inventory",
		"sources": "https://github.com/CeLDaemon/fabric-entity-inventory"
	},
	"license": "CC0-1.0",
	"icon": "assets/entity-inventory/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"net.voidgroup.proto.entityinventory.EntityInventory"
		],
		"client": [
			"net.voidgroup.proto.entityinventory.client.EntityInventoryClient"
		],
		"fabric-datagen": [
			"net.voidgroup.proto.entityinventory.client.EntityInventoryDataGenerator"
		]
	},
	"depends": {
		"fabricloader": ">=0.18.6",
		"minecraft": "~26.1",
		"java": ">=25",
		"fabric-api": "*"
	},
	"mixins": ["entity-inventory.mixin.json"]
}